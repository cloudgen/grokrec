# =============================================================================
main() {
    if [ ! -f "$0" ] || [ -z "${0##*sh}" ] || [ "${FORCE_REINSTALL}" = "1" ]; then
        if [ "${JSON_OUTPUT}" -eq 1 ] || [ "${QUIET}" -eq 1 ] || [ "${TTY}" -eq 0 ]; then
            info "Running in non-interactive mode → performing silent installation"
            perform_install
            exit 0
        else
            plain ""
            plain "${APP_NAME} is not installed yet."
            printf "Would you like to install it now? (y/N): "
            read -r answer
            case "${answer}" in
                [yY]|[yY][eE][sS])
                    perform_install
                    ;;
                *)
                    plain "Installation cancelled by user."
                    exit 0
                    ;;
            esac
        fi
        exit 0
    fi

    cmd="start"

    while [ $# -gt 0 ]; do
        case "$1" in
            --quiet|-q) QUIET=1 ;;
            --json)     JSON_OUTPUT=1; QUIET=1 ;;
            --*)        ;;
            -*)         ;;
            *)          cmd="$1" ;;
        esac
        shift
    done

    [ "${JSON_OUTPUT}" -eq 0 ] && [ "${QUIET}" -eq 0 ] && [ "${TTY}" -eq 1 ] && COLOR=1

    case "${cmd}" in
        about)       cmd_about ;;
        self-update) cmd_self_update ;;
        help|--help|-h) cmd_help ;;
        start)       cmd_start ;;
        *)
            if [ "${JSON_OUTPUT}" -eq 1 ]; then
                output_json_error "Unknown command: ${cmd}"
            else
                error "Unknown command: ${cmd}"
                plain "Run '${APP_NAME} help' for usage."
            fi
            exit 1
            ;;
    esac

    exit 0
}

# =============================================================================
# Invoke the single entry point
# =============================================================================
main "$@"