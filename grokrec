# - Version checking logic gets broken
# - Edge cases in non-interactive environments are ignored
#
# This function is battle-field tested and must continue to fully respect
# --quiet (suppressing all non-error output) while still performing safe
# version-aware self-update.
#
# Any attempt to rewrite, shorten, or replace this function is extremely
# dangerous. We must intentionally reuse and preserve the existing logic
# instead of letting AI "improve" it. Respecting --quiet and resisting
# simplification is a core part of CIAO Caution and Anti-fragility.
#
# Last reviewed: April 2026
# =============================================================================

self_update() {
    if [ "${JSON}" -eq 0 ]; then
        info "Starting self-update of ${APP_NAME}..."
    fi

    local REMOTE_VERSION
    REMOTE_VERSION=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$REMOTE_VERSION" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Failed to fetch latest version" "network_error"
        else
            error "Failed to fetch latest version"
        fi
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    if [ "$local_version" = "$REMOTE_VERSION" ] && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "success" "message" "Already running the latest version (${REMOTE_VERSION})."
        else
            success "Already running the latest version (${REMOTE_VERSION})."
        fi
        return 0
    fi

    if [ "$local_version" != "$REMOTE_VERSION" ] && [ "${JSON}" -eq 0 ]; then
        info "Updating from ${local_version} → ${REMOTE_VERSION}"
    fi

    FORCE_REINSTALL=1
    perform_self_install
}

